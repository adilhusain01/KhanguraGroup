# App
VITE_SITE_URL=http://localhost:3000

# MongoDB Atlas: use separate preview and production databases
MONGODB_URI=mongodb+srv://...
MONGODB_DB=khangura_preview

# Better Auth — opens the admin only after invite-only configuration is ready
BETTER_AUTH_SECRET=generate_a_32_character_or_longer_secret
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000

# Cloudinary — never expose CLOUDINARY_API_SECRET in VITE_ variables
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_PUBLIC_FOLDER=khangura-preview/public
CLOUDINARY_PRIVATE_FOLDER=khangura-preview/private

# Turnstile and Meta WhatsApp Cloud API
TURNSTILE_SECRET_KEY=
VITE_TURNSTILE_SITE_KEY=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_INTERNAL_RECIPIENT=16723771944
WHATSAPP_TEMPLATE_NAME=new_enquiry
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
CRON_SECRET=

# Optional operations integrations
RESEND_API_KEY=
SENTRY_DSN=
VITE_SENTRY_DSN=
VITE_GA_MEASUREMENT_ID=

# One-time local bootstrap only — do not add these to Vercel.
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_NAME=
BOOTSTRAP_ADMIN_PASSWORD=
