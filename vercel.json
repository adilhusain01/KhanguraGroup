{
  "crons": [
    { "path": "/api/cron/retry-whatsapp", "schedule": "*/15 * * * *" },
    { "path": "/api/cron/retention", "schedule": "0 4 * * *" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
